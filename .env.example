# 复制为 .env 后填入（本地测试用，勿提交）
# GitHub Actions：同名变量配置为 Repository Secrets；线上配置真源为 config.user.json

# ── LLM（OpenAI 兼容接口，可换任意提供商）──
LLM_API_KEY=sk-xxx
# 向后兼容：若仍使用旧名 DEEPSEEK_API_KEY，程序会自动读取（LLM_API_KEY 优先）
# DEEPSEEK_API_KEY=sk-xxx
# config.user.json 中 llm.baseUrl / llm.model 需与 Key 对应，例如：
#   DeepSeek: baseUrl=https://api.deepseek.com/v1, model=deepseek-chat
#   OpenAI:   baseUrl=https://api.openai.com/v1, model=gpt-4o-mini

# ── 推送：企业微信群机器人 Webhook（推荐）──
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ── 推送：飞书 / Discord（可选，config.json 中 enabled 控制）──
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ── GitHub Pages 全文链接（可选，digest 企微消息中的「完整版」URL）──
# 示例：https://yourname.github.io/ai-daily/
# 未设置时 GHA 可从 GITHUB_REPOSITORY 自动推断
# PAGES_BASE_URL=https://yourname.github.io/ai-daily/
# GITHUB_TOKEN=ghp_xxx
# JINA_API_KEY=jina_xxx
